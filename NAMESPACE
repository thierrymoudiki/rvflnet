# S3 methods for rvflnet class
S3method(print, rvflnet)
S3method(predict, rvflnet)
S3method(coef, rvflnet)
S3method(fitted, rvflnet)
S3method(residuals, rvflnet)
S3method(summary, rvflnet)
S3method(plot, rvflnet)

# S3 methods for cv.rvflnet class
S3method(print, cv.rvflnet)
S3method(predict, cv.rvflnet)
S3method(coef, cv.rvflnet)
S3method(fitted, cv.rvflnet)
S3method(residuals, cv.rvflnet)
S3method(summary, cv.rvflnet)
S3method(plot, cv.rvflnet)

# Export main user-facing functions
export(rvflnet)
export(cv.rvflnet)

# Export helper functions
export(is.rvflnet)
export(is.cv.rvflnet)
export(n_hidden)
export(get_activation)
export(get_weight_type)
export(best_lambda)

# Import packages
import(glmnet)
importFrom(randtoolbox, sobol)
importFrom("stats", "coef", "fitted", "predict", "qnorm", "rnorm",
             "runif", "sd")

# S3 method registration for generic functions
export(print.rvflnet)
export(predict.rvflnet)
export(coef.rvflnet)
export(fitted.rvflnet)
export(residuals.rvflnet)
export(summary.rvflnet)
export(plot.rvflnet)

export(print.cv.rvflnet)
export(predict.cv.rvflnet)
export(coef.cv.rvflnet)
export(fitted.cv.rvflnet)
export(residuals.cv.rvflnet)
export(summary.cv.rvflnet)
